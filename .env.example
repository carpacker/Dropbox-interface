# Copy this file to `.env.local` and fill in values.
# `.env.local` is git-ignored.

# Dropbox app key (from https://www.dropbox.com/developers/apps).
# Use "Scoped access" → "App folder" or "Full Dropbox" depending on what
# you want to browse. PKCE flow uses no secret, so this key ships in the
# bundle and is fine to commit if you must.
VITE_DROPBOX_APP_KEY=
